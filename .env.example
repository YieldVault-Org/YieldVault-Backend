# Server configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# CORS: comma-separated allowlist of origins, or '*' to allow any
CORS_ORIGINS=*

# Mock Stellar / Soroban network settings
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Yield accrual settings
# Base APY applied to vaults when none is specified (as a decimal, e.g. 0.08 = 8%)
DEFAULT_APY=0.08

# Rate limiting (fixed window per client IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Request handling
# Abort a request that runs longer than this many milliseconds (503)
REQUEST_TIMEOUT_MS=15000
# Maximum accepted JSON request body size (e.g. 64kb, 1mb)
BODY_LIMIT=64kb
