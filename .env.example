# Server configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Mock Stellar / Soroban network settings
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Yield accrual settings
# Base APY applied to vaults when none is specified (as a decimal, e.g. 0.08 = 8%)
DEFAULT_APY=0.08

# Rate limiting (fixed window per client IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
